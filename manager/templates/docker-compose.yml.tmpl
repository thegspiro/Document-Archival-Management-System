services:
  db:
    image: mysql:8.0
    restart: unless-stopped
    env_file: .env
    volumes:
      - mysql_data:/var/lib/mysql
    ports:
      - "{{MYSQL_PORT}}:3306"
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 5
    command: >
      --character-set-server=utf8mb4
      --collation-server=utf8mb4_unicode_ci
      --default-authentication-plugin=mysql_native_password

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    volumes:
      - redis_data:/data
    ports:
      - "{{REDIS_PORT}}:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  backend:
    image: adms-backend:latest
    restart: unless-stopped
    env_file: .env
    environment:
      MYSQL_HOST: db
      MYSQL_PORT: 3306
    volumes:
      - {{STORAGE_PATH}}:/data/storage
    ports:
      - "{{BACKEND_PORT}}:8000"
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy

  worker:
    image: adms-backend:latest
    restart: unless-stopped
    command: celery -A app.workers.celery_app worker --loglevel=info --concurrency=4
    env_file: .env
    environment:
      MYSQL_HOST: db
      MYSQL_PORT: 3306
    volumes:
      - {{STORAGE_PATH}}:/data/storage
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy

  beat:
    image: adms-backend:latest
    restart: unless-stopped
    command: celery -A app.workers.celery_app beat --loglevel=info
    env_file: .env
    environment:
      MYSQL_HOST: db
      MYSQL_PORT: 3306
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy

  frontend:
    image: adms-frontend:latest
    restart: unless-stopped
    ports:
      - "{{FRONTEND_PORT}}:80"
    depends_on:
      - backend

  nocodb:
    image: nocodb/nocodb:latest
    restart: unless-stopped
    env_file: .env
    ports:
      - "{{NOCODB_PORT}}:8080"
    depends_on:
      db:
        condition: service_healthy

volumes:
  mysql_data:
  redis_data:
