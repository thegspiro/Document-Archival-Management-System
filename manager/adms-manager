#!/bin/sh
# adms-manager — Multi-instance management for ADMS
# POSIX sh. No bash-specific syntax.
set -eu

VERSION="0.1.0"
REGISTRY="${ADMS_REGISTRY_PATH:-$HOME/.adms/registry}"
INSTANCE_BASE="${ADMS_INSTANCE_BASE:-/opt/adms/instances}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TEMPLATE_DIR="$SCRIPT_DIR/templates"

# Port base values
BASE_FRONTEND_PORT=3001
BASE_BACKEND_PORT=8001
BASE_MYSQL_PORT=3307
BASE_REDIS_PORT=6380
BASE_NOCODB_PORT=8081

usage() {
    cat <<EOF
adms-manager v$VERSION — Multi-instance ADMS management

Usage: adms-manager <command> [options]

Commands:
  create [name]           Create a new ADMS instance (interactive)
  list                    List all registered instances
  start <name>            Start an instance
  stop <name>             Stop an instance
  restart <name>          Stop then start an instance
  update <name>           Pull latest images, run migrations, restart
  backup <name>           Create a backup archive
  restore <name> <file>   Restore from a backup archive
  logs <name> [service]   Tail logs for an instance
  status <name>           Show instance status
  proxy-config            Generate nginx config for all instances
  destroy <name>          Permanently remove an instance

Options:
  --help                  Show this help
  --version               Show version
EOF
}

ensure_registry() {
    mkdir -p "$(dirname "$REGISTRY")"
    if [ ! -f "$REGISTRY" ]; then
        cat > "$REGISTRY" <<HEADER
# adms instance registry
# format: name|directory|domain|frontend_port|backend_port|mysql_port|redis_port|nocodb_port|created_at
HEADER
    fi
}

next_port_block() {
    ensure_registry
    max_n=0
    while IFS='|' read -r name dir domain fp bp mp rp np created; do
        case "$name" in \#*|"") continue ;; esac
        n=$((fp - BASE_FRONTEND_PORT + 1))
        if [ "$n" -gt "$max_n" ]; then max_n=$n; fi
    done < "$REGISTRY"
    echo $((max_n + 1))
}

cmd_create() {
    ensure_registry
    name="${1:-}"

    if [ -z "$name" ]; then
        printf "Instance name (lowercase, hyphens): "
        read -r name
    fi

    # Validate name
    case "$name" in
        *[!a-z0-9-]*) echo "Error: Name must be lowercase letters, numbers, and hyphens only." >&2; exit 1 ;;
    esac

    # Check if exists
    if grep -q "^${name}|" "$REGISTRY" 2>/dev/null; then
        echo "Error: Instance '$name' already exists." >&2; exit 1
    fi

    printf "Institution name: "; read -r inst_name
    printf "Public domain (e.g., archive.example.org): "; read -r domain
    printf "Storage path on host (e.g., /mnt/user/adms/$name/storage): "; read -r storage_path
    printf "Admin email: "; read -r admin_email

    n=$(next_port_block)
    fp=$((BASE_FRONTEND_PORT + n - 1))
    bp=$((BASE_BACKEND_PORT + n - 1))
    mp=$((BASE_MYSQL_PORT + n - 1))
    rp=$((BASE_REDIS_PORT + n - 1))
    np=$((BASE_NOCODB_PORT + n - 1))

    inst_dir="$INSTANCE_BASE/$name"
    mkdir -p "$inst_dir/backups"
    mkdir -p "$storage_path"

    # Generate .env
    secret_key=$(head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n')
    mysql_password=$(head -c 16 /dev/urandom | od -An -tx1 | tr -d ' \n')
    mysql_root_password=$(head -c 16 /dev/urandom | od -An -tx1 | tr -d ' \n')

    sed \
        -e "s|{{INSTANCE_NAME}}|$name|g" \
        -e "s|{{INSTITUTION_NAME}}|$inst_name|g" \
        -e "s|{{DOMAIN}}|$domain|g" \
        -e "s|{{SECRET_KEY}}|$secret_key|g" \
        -e "s|{{MYSQL_PASSWORD}}|$mysql_password|g" \
        -e "s|{{MYSQL_ROOT_PASSWORD}}|$mysql_root_password|g" \
        -e "s|{{STORAGE_PATH}}|$storage_path|g" \
        -e "s|{{ADMIN_EMAIL}}|$admin_email|g" \
        "$TEMPLATE_DIR/env.tmpl" > "$inst_dir/.env"

    # Generate docker-compose.yml
    sed \
        -e "s|{{FRONTEND_PORT}}|$fp|g" \
        -e "s|{{BACKEND_PORT}}|$bp|g" \
        -e "s|{{MYSQL_PORT}}|$mp|g" \
        -e "s|{{REDIS_PORT}}|$rp|g" \
        -e "s|{{NOCODB_PORT}}|$np|g" \
        -e "s|{{STORAGE_PATH}}|$storage_path|g" \
        "$TEMPLATE_DIR/docker-compose.yml.tmpl" > "$inst_dir/docker-compose.yml"

    # Symlink storage
    ln -sf "$storage_path" "$inst_dir/data"

    # Add to registry
    created_at=$(date -u +%Y-%m-%d)
    echo "${name}|${inst_dir}|${domain}|${fp}|${bp}|${mp}|${rp}|${np}|${created_at}" >> "$REGISTRY"

    echo ""
    echo "Instance '$name' created at $inst_dir"
    echo "  Domain:   $domain"
    echo "  Frontend: :$fp"
    echo "  Backend:  :$bp"
    echo "  MySQL:    :$mp"
    echo "  Redis:    :$rp"
    echo "  NoCoDB:   :$np"
    echo ""
    echo "Run 'adms-manager start $name' to start the instance."
}

cmd_list() {
    ensure_registry
    printf "%-25s %-30s %-8s %-8s %s\n" "NAME" "DOMAIN" "FRONT" "BACK" "CREATED"
    printf "%-25s %-30s %-8s %-8s %s\n" "----" "------" "-----" "----" "-------"
    while IFS='|' read -r name dir domain fp bp mp rp np created; do
        case "$name" in \#*|"") continue ;; esac
        printf "%-25s %-30s %-8s %-8s %s\n" "$name" "$domain" ":$fp" ":$bp" "$created"
    done < "$REGISTRY"
}

cmd_start() {
    name="$1"
    dir=$(grep "^${name}|" "$REGISTRY" | cut -d'|' -f2)
    [ -z "$dir" ] && echo "Instance '$name' not found." >&2 && exit 1
    echo "Starting $name..."
    docker compose -p "adms-${name}" -f "$dir/docker-compose.yml" up -d
    echo "Instance '$name' started."
}

cmd_stop() {
    name="$1"
    dir=$(grep "^${name}|" "$REGISTRY" | cut -d'|' -f2)
    [ -z "$dir" ] && echo "Instance '$name' not found." >&2 && exit 1
    echo "Stopping $name..."
    docker compose -p "adms-${name}" -f "$dir/docker-compose.yml" stop
    echo "Instance '$name' stopped."
}

cmd_restart() {
    cmd_stop "$1"
    cmd_start "$1"
}

cmd_update() {
    name="$1"
    dir=$(grep "^${name}|" "$REGISTRY" | cut -d'|' -f2)
    [ -z "$dir" ] && echo "Instance '$name' not found." >&2 && exit 1
    echo "Updating $name..."
    docker compose -p "adms-${name}" -f "$dir/docker-compose.yml" pull
    docker compose -p "adms-${name}" -f "$dir/docker-compose.yml" run --rm backend alembic upgrade head
    docker compose -p "adms-${name}" -f "$dir/docker-compose.yml" up -d
    echo "Instance '$name' updated."
}

cmd_backup() {
    name="$1"
    dir=$(grep "^${name}|" "$REGISTRY" | cut -d'|' -f2)
    [ -z "$dir" ] && echo "Instance '$name' not found." >&2 && exit 1
    timestamp=$(date -u +%Y-%m-%dT%H%M)
    backup_file="$dir/backups/${timestamp}.tar.gz"
    echo "Backing up $name..."

    # MySQL dump
    docker compose -p "adms-${name}" -f "$dir/docker-compose.yml" \
        exec -T db mysqldump -u root -p"$(grep MYSQL_ROOT_PASSWORD "$dir/.env" | cut -d= -f2)" \
        --all-databases > "$dir/backups/db_${timestamp}.sql"

    # Create archive
    tar czf "$backup_file" -C "$dir" ".env" "backups/db_${timestamp}.sql"
    rm "$dir/backups/db_${timestamp}.sql"

    echo "Backup created: $backup_file"
}

cmd_logs() {
    name="$1"
    service="${2:-}"
    dir=$(grep "^${name}|" "$REGISTRY" | cut -d'|' -f2)
    [ -z "$dir" ] && echo "Instance '$name' not found." >&2 && exit 1
    if [ -n "$service" ]; then
        docker compose -p "adms-${name}" -f "$dir/docker-compose.yml" logs -f "$service"
    else
        docker compose -p "adms-${name}" -f "$dir/docker-compose.yml" logs -f
    fi
}

cmd_status() {
    name="$1"
    dir=$(grep "^${name}|" "$REGISTRY" | cut -d'|' -f2)
    [ -z "$dir" ] && echo "Instance '$name' not found." >&2 && exit 1
    docker compose -p "adms-${name}" -f "$dir/docker-compose.yml" ps
}

cmd_proxy_config() {
    ensure_registry
    while IFS='|' read -r name dir domain fp bp mp rp np created; do
        case "$name" in \#*|"") continue ;; esac
        cat <<NGINX
server {
    listen 80;
    server_name $domain;
    location / {
        proxy_pass http://localhost:$fp;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }
}

NGINX
    done < "$REGISTRY"
}

cmd_destroy() {
    name="$1"
    dir=$(grep "^${name}|" "$REGISTRY" | cut -d'|' -f2)
    [ -z "$dir" ] && echo "Instance '$name' not found." >&2 && exit 1

    echo "WARNING: This will permanently remove instance '$name'."
    echo "  Directory: $dir"
    printf "Type the instance name to confirm: "
    read -r confirm
    [ "$confirm" != "$name" ] && echo "Aborted." && exit 1

    echo "Destroying $name..."
    docker compose -p "adms-${name}" -f "$dir/docker-compose.yml" down -v 2>/dev/null || true
    rm -rf "$dir"
    grep -v "^${name}|" "$REGISTRY" > "${REGISTRY}.tmp" && mv "${REGISTRY}.tmp" "$REGISTRY"
    echo "Instance '$name' destroyed."
}

# Main dispatch
case "${1:-}" in
    create)       shift; cmd_create "${1:-}" ;;
    list)         cmd_list ;;
    start)        shift; cmd_start "$1" ;;
    stop)         shift; cmd_stop "$1" ;;
    restart)      shift; cmd_restart "$1" ;;
    update)       shift; cmd_update "$1" ;;
    backup)       shift; cmd_backup "$1" ;;
    logs)         shift; cmd_logs "$1" "${2:-}" ;;
    status)       shift; cmd_status "$1" ;;
    proxy-config) cmd_proxy_config ;;
    destroy)      shift; cmd_destroy "$1" ;;
    --version)    echo "adms-manager v$VERSION" ;;
    --help|"")    usage ;;
    *)            echo "Unknown command: $1" >&2; usage; exit 1 ;;
esac
